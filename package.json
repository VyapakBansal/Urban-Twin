{
  "name": "urban-twin",
  "private": true,
  "version": "0.5.0",
  "description": "Kensington neighbourhood digital twin — one-command local stack",
  "scripts": {
    "up": "bash scripts/up.sh",
    "down": "bash scripts/down.sh",
    "down:all": "bash scripts/down.sh --docker",
    "dev": "bash scripts/up.sh --with-frontend",
    "train": "bash -c '.venv/Scripts/python.exe -m urban_twin.forecast.train \"$@\"' --",
    "validate": "bash -c '.venv/Scripts/python.exe -m urban_twin.forecast.main --validate \"$@\"' --",
    "ingest": "bash -c '.venv/Scripts/python.exe -m urban_twin.ingestion.main --once \"$@\"' --",
    "forecast": "bash -c '.venv/Scripts/python.exe -m urban_twin.forecast.main --once \"$@\"' --",
    "drone": "bash scripts/drone.sh",
    "drone:bridge": "bash scripts/drone.sh --skip-sim",
    "drone:sim": "bash scripts/drone.sh --sim-only",
    "frontend": "npm --prefix frontend run dev"
  }
}
