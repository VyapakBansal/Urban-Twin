# Copy to .env and fill in values.
# cp .env.example .env

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://urban:urban@localhost:5433/urban_twin
DATABASE_URL_SYNC=postgresql+psycopg://urban:urban@localhost:5433/urban_twin

# --- Target neighborhood (WGS84 bounding box) ---
# Default: Kensington, Calgary, AB (Hillhurst–Sunnyside district)
AOI_NAME=Kensington Calgary
AOI_MIN_LON=-114.100
AOI_MIN_LAT=51.048
AOI_MAX_LON=-114.062
AOI_MAX_LAT=51.062

# Station used for OpenWeather current weather (approx AOI center)
STATION_ID=calgary-kensington-1
STATION_LAT=51.053
STATION_LON=-114.081

# --- OpenWeather ---
# Free key: https://openweathermap.org/api
# NEVER commit a real key. Put it only in local .env (gitignored).
OPENWEATHER_API_KEY=
INGESTION_POLL_INTERVAL_SEC=300

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SENSOR_READINGS=sensor.readings
KAFKA_TOPIC_FORECASTS=forecasts.generated
KAFKA_TOPIC_DRONE_TELEMETRY=drone.telemetry
KAFKA_TOPIC_DRONE_CONTROL=drone.control

# --- WebSocket bridge ---
# Local: 127.0.0.1. Azure (behind nginx): 127.0.0.1 still (nginx proxies :80 → :8001)
WS_BRIDGE_HOST=127.0.0.1
WS_BRIDGE_PORT=8001

# --- PX4 / MAVSDK drone bridge ---
# Setup: docs/DRONE.md  |  Errors: docs/DRONE_TROUBLESHOOTING.md
# PX4 SITL sends MAVLink to UDP 14540. Use udpin:// on Windows/WSL2.
DRONE_SYSTEM_ADDRESS=udpin://0.0.0.0:14540
DRONE_ID=px4-sitl-1
# Must match the PX4/Gazebo home origin; altitude uses the WGS84 ellipsoid.
DRONE_HOME_LAT=51.053
DRONE_HOME_LON=-114.081
DRONE_HOME_ALT_M=1045.0
DRONE_TELEMETRY_HZ=20
DRONE_CONTROL_HZ=20
DRONE_COMMAND_TIMEOUT_SEC=0.5
DRONE_MAX_HORIZONTAL_SPEED_M_S=5
DRONE_MAX_VERTICAL_SPEED_M_S=2
DRONE_MAX_YAW_RATE_DEG_S=60
DRONE_MIN_ALTITUDE_M=2
DRONE_MAX_ALTITUDE_M=120

# --- REST API ---
# Local: 127.0.0.1. Azure (behind nginx): 127.0.0.1 (nginx proxies /api → :8000)
API_HOST=127.0.0.1
API_PORT=8000
API_RATE_LIMIT=60/minute
# Comma-separated. Azure: add http://<public-ip>
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Forecast (LightGBM multi-horizon, ~5y training) ---
FORECAST_HORIZON_HOURS=24
FORECAST_HORIZONS=1,2,3,6,12,24,48
FORECAST_INTERVAL_SEC=900
FORECAST_MODEL_VERSION=lgbm-mh-v1
FORECAST_READING_TYPE=temp
FORECAST_TARGETS=temp,river_level,aqi_pm25
FORECAST_TRAIN_DAYS=1826
FORECAST_MODEL_DIR=models

# --- Multi-source ingest ---
OPENAQ_API_KEY=
RIVER_STATION_ID=05BH004
INGEST_SOURCES=weather,river,air,incidents,pathways,amenities

# --- Supabase (optional cloud Postgres — see docs/DEPLOY.md) ---
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@….pooler.supabase.com:6543/postgres
# DATABASE_URL_SYNC=postgresql+psycopg://postgres.[ref]:[password]@….pooler.supabase.com:5432/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
