# Copy to .env and fill in values.
# cp .env.example .env

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://urban:urban@localhost:5433/urban_twin
DATABASE_URL_SYNC=postgresql+psycopg://urban:urban@localhost:5433/urban_twin

# --- Target neighborhood (WGS84 bounding box) ---
# Default: Kensington, Calgary, AB (Hillhurst–Sunnyside district)
# Roughly: Bow River (S), McHugh Bluff / Crescent Rd (N),
#          ~14 St NW (W), Centre St (E)
AOI_NAME=Kensington Calgary
AOI_MIN_LON=-114.100
AOI_MIN_LAT=51.048
AOI_MAX_LON=-114.062
AOI_MAX_LAT=51.062

# Station used for OpenWeather current weather (approx AOI center)
STATION_ID=calgary-kensington-1
STATION_LAT=51.053
STATION_LON=-114.081

# --- OpenWeather ---
# Free key: https://openweathermap.org/api
# NEVER commit a real key. Put it only in local .env (gitignored).
# If a key appears in a terminal log or chat, rotate it immediately.
OPENWEATHER_API_KEY=
# Poll interval in seconds (One Call / Current Weather free tier: typically 60 calls/min;
# for Current Weather, every 5–10 min is plenty — set after confirming your plan limits)
INGESTION_POLL_INTERVAL_SEC=300

# --- Kafka (Week 2) ---
# Matches docker-compose kafka service advertised on the host
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SENSOR_READINGS=sensor.readings
KAFKA_TOPIC_FORECASTS=forecasts.generated

# --- WebSocket bridge ---
WS_BRIDGE_HOST=127.0.0.1
WS_BRIDGE_PORT=8001

# --- REST API (Week 3) ---
API_HOST=127.0.0.1
API_PORT=8000
API_RATE_LIMIT=60/minute

# --- Forecast worker (Week 3) ---
FORECAST_HORIZON_HOURS=1
FORECAST_INTERVAL_SEC=900
FORECAST_MODEL_VERSION=persistence-v1
FORECAST_READING_TYPE=temp
